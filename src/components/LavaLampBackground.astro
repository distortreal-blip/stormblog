---

---

<div class="lava-bg" aria-hidden="true">
	<div class="lava-bg__base"></div>
	<div class="lava-bg__blob lava-bg__blob--1"></div>
	<div class="lava-bg__blob lava-bg__blob--2"></div>
	<div class="lava-bg__blob lava-bg__blob--3"></div>
	<div class="lava-bg__blob lava-bg__blob--4"></div>
	<div class="lava-bg__blob lava-bg__blob--5"></div>
	<div class="lava-bg__vignette"></div>
</div>

<style>
	.lava-bg {
		position: fixed;
		inset: 0;
		z-index: -1;
		overflow: hidden;
		pointer-events: none;
		background: #030303;
	}

	.lava-bg__base {
		position: absolute;
		inset: 0;
		background: radial-gradient(ellipse 120% 80% at 50% 100%, #0a0a0a 0%, #030303 55%, #000 100%);
	}

	.lava-bg__blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(72px);
		will-change: transform;
	}

	.lava-bg__blob--1 {
		width: 42vmin;
		height: 42vmin;
		top: 8%;
		left: 12%;
		background: radial-gradient(circle at 35% 35%, #1c1c1c 0%, #101010 45%, #080808 100%);
		opacity: 0.55;
		animation: lava-drift-1 28s ease-in-out infinite;
	}

	.lava-bg__blob--2 {
		width: 52vmin;
		height: 52vmin;
		top: 42%;
		right: 6%;
		background: radial-gradient(circle at 40% 30%, #222 0%, #141414 50%, #090909 100%);
		opacity: 0.42;
		animation: lava-drift-2 34s ease-in-out infinite;
	}

	.lava-bg__blob--3 {
		width: 36vmin;
		height: 48vmin;
		bottom: 10%;
		left: 28%;
		border-radius: 46% 54% 52% 48% / 48% 42% 58% 52%;
		background: radial-gradient(circle at 50% 40%, #181818 0%, #0e0e0e 55%, #060606 100%);
		opacity: 0.48;
		animation: lava-drift-3 24s ease-in-out infinite;
	}

	.lava-bg__blob--4 {
		width: 28vmin;
		height: 34vmin;
		top: 22%;
		right: 32%;
		border-radius: 52% 48% 45% 55% / 55% 45% 55% 45%;
		background: radial-gradient(circle at 45% 55%, #1a1a1a 0%, #111 60%, #070707 100%);
		opacity: 0.38;
		animation: lava-drift-4 20s ease-in-out infinite;
	}

	.lava-bg__blob--5 {
		width: 58vmin;
		height: 38vmin;
		bottom: 18%;
		right: 22%;
		border-radius: 58% 42% 50% 50% / 42% 58% 42% 58%;
		background: radial-gradient(circle at 60% 40%, #151515 0%, #0c0c0c 50%, #050505 100%);
		opacity: 0.35;
		animation: lava-drift-5 32s ease-in-out infinite;
	}

	.lava-bg__vignette {
		position: absolute;
		inset: 0;
		background: radial-gradient(ellipse 90% 70% at 50% 50%, transparent 35%, rgba(0, 0, 0, 0.55) 100%);
	}

	@keyframes lava-drift-1 {
		0%,
		100% {
			transform: translate(0, 0) scale(1) rotate(0deg);
			border-radius: 50%;
		}
		33% {
			transform: translate(8vw, 12vh) scale(1.08) rotate(8deg);
			border-radius: 48% 52% 54% 46% / 52% 46% 54% 48%;
		}
		66% {
			transform: translate(-4vw, 6vh) scale(0.94) rotate(-6deg);
			border-radius: 54% 46% 48% 52% / 46% 54% 46% 54%;
		}
	}

	@keyframes lava-drift-2 {
		0%,
		100% {
			transform: translate(0, 0) scale(1);
			border-radius: 50%;
		}
		40% {
			transform: translate(-10vw, -8vh) scale(1.12);
			border-radius: 46% 54% 50% 50% / 54% 46% 54% 46%;
		}
		70% {
			transform: translate(5vw, 10vh) scale(0.9);
			border-radius: 52% 48% 46% 54% / 48% 52% 48% 52%;
		}
	}

	@keyframes lava-drift-3 {
		0%,
		100% {
			transform: translate(0, 0) scale(1) rotate(0deg);
		}
		50% {
			transform: translate(12vw, -14vh) scale(1.15) rotate(12deg);
		}
	}

	@keyframes lava-drift-4 {
		0%,
		100% {
			transform: translate(0, 0) scale(1);
		}
		25% {
			transform: translate(-6vw, 8vh) scale(1.1);
		}
		75% {
			transform: translate(7vw, -5vh) scale(0.88);
		}
	}

	@keyframes lava-drift-5 {
		0%,
		100% {
			transform: translate(0, 0) scale(1) rotate(0deg);
			border-radius: 58% 42% 50% 50% / 42% 58% 42% 58%;
		}
		45% {
			transform: translate(-8vw, 6vh) scale(1.06) rotate(-10deg);
			border-radius: 44% 56% 52% 48% / 56% 44% 56% 44%;
		}
		80% {
			transform: translate(6vw, -9vh) scale(0.96) rotate(7deg);
			border-radius: 50% 50% 44% 56% / 48% 52% 48% 52%;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.lava-bg__blob {
			animation: none;
		}
	}
</style>
