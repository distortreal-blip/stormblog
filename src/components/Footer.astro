---
import { MAIN_SITE_URL } from '../consts';

const year = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
	<div class="site-footer__grid">
		<div>
			<p class="site-footer__brand">Storm Cloud</p>
			<p class="site-footer__tagline">
				Практичные статьи о VPS, DevOps и облачной инфраструктуре.
			</p>
		</div>
		<nav class="site-footer__nav" aria-label="Навигация в подвале">
			<a href="/">Главная</a>
			<a href="/blog">Статьи</a>
			<a href="/tools">Инструменты</a>
			<a href="/author/">Редакция</a>
			<a href="/about">О проекте</a>
			<a href={MAIN_SITE_URL} target="_blank" rel="noopener noreferrer">Перейти на StormNet Cloud</a>
		</nav>
	</div>
	<div class="site-footer__bottom">
		<span>© {year} Storm Cloud</span>
	</div>
</footer>
