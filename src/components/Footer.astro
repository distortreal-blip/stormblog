---
import SocialLinks from './SocialLinks.astro';

const today = new Date();
---

<footer>
	<p class="copyright">&copy; {today.getFullYear()} Storm Cloud Blog. Все права защищены.</p>
	<p class="tagline">VPS, облака и инфраструктура для разработчиков</p>
	<SocialLinks />
</footer>
<style>
	footer {
		padding: 2.5em 1em 4em;
		border-top: 1px solid var(--border);
		background: var(--bg-elevated);
		color: rgb(var(--gray));
		text-align: center;
	}

	.copyright {
		margin: 0 0 0.35em;
		font-size: 0.95rem;
		color: rgb(var(--gray-dark));
	}

	.tagline {
		margin: 0 0 1.25em;
		font-size: 0.85rem;
	}

	footer :global(.social-links) {
		justify-content: center;
	}
</style>
