---
import { INSTAGRAM_URL, MAIN_SITE_URL, TIKTOK_URL } from '../consts';

const today = new Date();
---

<footer class="site-footer" role="contentinfo">
	<span class="site-footer__left">Storm Cloud Blog</span>
	<div class="site-footer__links">
		<a href={MAIN_SITE_URL} target="_blank" rel="noopener noreferrer">StormNet Cloud</a>
		<a href={INSTAGRAM_URL} target="_blank" rel="noopener noreferrer">Instagram</a>
		<a href={TIKTOK_URL} target="_blank" rel="noopener noreferrer">TikTok</a>
	</div>
	<span class="site-footer__right">{today.getFullYear()}</span>
</footer>
