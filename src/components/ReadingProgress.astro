<div class="reading-progress" aria-hidden="true">
	<div class="reading-progress__bar" id="reading-progress-bar"></div>
</div>

<script>
	function updateReadingProgress() {
		const bar = document.getElementById('reading-progress-bar');
		const article = document.querySelector('.article-shell');
		if (!bar || !article) return;

		const rect = article.getBoundingClientRect();
		const total = Math.max(article.scrollHeight - window.innerHeight, 1);
		const scrolled = window.scrollY - (article.offsetTop - 80);
		const progress = Math.min(100, Math.max(0, (scrolled / total) * 100));
		bar.style.width = `${progress}%`;
	}

	updateReadingProgress();
	window.addEventListener('scroll', updateReadingProgress, { passive: true });
	window.addEventListener('resize', updateReadingProgress);
</script>
