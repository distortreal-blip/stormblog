---
import type { GuideConfig } from '../data/seo';

interface Props {
	guide: GuideConfig;
}

const { guide } = Astro.props;
const count = guide.articleSlugs.length;
const countLabel =
	count % 10 === 1 && count % 100 !== 11
		? `${count} статья`
		: count % 10 >= 2 && count % 10 <= 4 && (count % 100 < 10 || count % 100 >= 20)
			? `${count} статьи`
			: `${count} статей`;
---

<li class="guide-card" data-guide={guide.slug}>
	<a class="guide-card__link" href={`/blog/guide/${guide.slug}/`}>
		<div class="guide-card__visual" aria-hidden="true">
			<div class="guide-card__gradient"></div>
			<div class="guide-card__grid"></div>
			<div class="guide-card__glow"></div>
			<span class="guide-card__badge">{countLabel}</span>
		</div>
		<div class="guide-card__body">
			<h3>{guide.title}</h3>
			<p>{guide.description}</p>
		</div>
	</a>
</li>
