---
interface Crumb {
	label: string;
	href?: string;
}

interface Props {
	items: Crumb[];
}

const { items } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Хлебные крошки">
	{
		items.map((item, index) => (
			<>
				{index > 0 && <span class="breadcrumbs__sep">/</span>}
				{item.href ? <a href={item.href}>{item.label}</a> : <span>{item.label}</span>}
			</>
		))
	}
</nav>
