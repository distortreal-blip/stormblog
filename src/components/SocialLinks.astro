---
import { MAIN_SITE_URL, INSTAGRAM_URL, TIKTOK_URL } from '../consts';
---

<div class="social-links">
	<a href={MAIN_SITE_URL} target="_blank" rel="noopener noreferrer" class="cta-link">
		<svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20">
			<path
				fill="currentColor"
				d="M4 6a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6zm4 2v8h2.5l.5-4h2l.5 4H16V8h-2v5.5L13.5 8H12l-.5 3.5L11 8H8z"
			></path>
		</svg>
		<span>Арендовать VPS</span>
	</a>
	<a href={INSTAGRAM_URL} target="_blank" rel="noopener noreferrer">
		<span class="sr-only">Instagram StormNet Cloud</span>
		<svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22">
			<path
				fill="currentColor"
				d="M7.8 2h8.4A5.8 5.8 0 0 1 22 7.8v8.4A5.8 5.8 0 0 1 16.2 22H7.8A5.8 5.8 0 0 1 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2zm0 2A3.8 3.8 0 0 0 4 7.8v8.4A3.8 3.8 0 0 0 7.8 20h8.4a3.8 3.8 0 0 0 3.8-3.8V7.8A3.8 3.8 0 0 0 16.2 4H7.8zm9.65 1.5a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5zM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6z"
			></path>
		</svg>
	</a>
	<a href={TIKTOK_URL} target="_blank" rel="noopener noreferrer">
		<span class="sr-only">TikTok StormNet Cloud</span>
		<svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22">
			<path
				fill="currentColor"
				d="M16.6 5.82s.51.5 0 0A4.28 4.28 0 0 1 15.54 3h-3.09v12.4a2.59 2.59 0 0 1-2.59 2.5c-1.42 0-2.6-1.16-2.6-2.6 0-1.72 1.66-3.01 3.37-2.48V9.66c-3.45-.46-6.47 2.22-6.47 5.64 0 3.33 2.76 5.7 5.69 5.7 3.14 0 5.69-2.55 5.69-5.7V9.01a7.35 7.35 0 0 0 4.3 1.38V7.3a4.1 4.1 0 0 1-1-.48z"
			></path>
		</svg>
	</a>
</div>

<style>
	.social-links {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.social-links a {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: rgb(var(--gray));
		transition: color 0.2s ease;
	}

	.social-links a:hover {
		color: var(--accent);
	}

	.cta-link {
		padding: 0.45rem 0.85rem;
		border: 1px solid var(--border);
		border-radius: 999px;
		background: var(--accent-glow);
		color: var(--accent) !important;
		font-size: 0.85rem;
		font-weight: 700;
		white-space: nowrap;
	}

	.cta-link:hover {
		background: rgba(34, 211, 238, 0.22);
		color: #67e8f9 !important;
	}
</style>
