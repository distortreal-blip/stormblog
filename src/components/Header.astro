---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import SocialLinks from './SocialLinks.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Главная</HeaderLink>
			<HeaderLink href="/blog">Блог</HeaderLink>
			<HeaderLink href="/about">О блоге</HeaderLink>
		</div>
		<SocialLinks />
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1.25em;
		background: rgba(17, 24, 39, 0.85);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border);
		position: sticky;
		top: 0;
		z-index: 100;
	}

	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a {
		text-decoration: none;
		color: rgb(var(--black));
		font-weight: 700;
		letter-spacing: -0.01em;
	}

	h2 a:hover {
		color: var(--accent);
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		max-width: 960px;
		margin: 0 auto;
	}

	.internal-links {
		display: flex;
		align-items: center;
	}

	nav a {
		padding: 1em 0.65em;
		color: rgb(var(--gray));
		border-bottom: 2px solid transparent;
		text-decoration: none;
		font-size: 0.95rem;
		transition:
			color 0.2s ease,
			border-color 0.2s ease;
	}

	nav a:hover {
		color: rgb(var(--black));
	}

	nav a.active {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}

	@media (max-width: 720px) {
		nav {
			flex-wrap: wrap;
			padding: 0.5em 0;
		}

		.internal-links {
			order: 3;
			width: 100%;
			justify-content: center;
		}

		nav a {
			padding: 0.75em 0.5em;
		}
	}
</style>
