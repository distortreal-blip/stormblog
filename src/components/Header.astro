---
import {
	INSTAGRAM_URL,
	MAIN_SITE_URL,
	SITE_TITLE,
	TIKTOK_URL,
} from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="topbar fade-in" id="site-topbar">
	<a href="/" class="brand">
		<svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
			<path
				d="M6.99958 19.0468C5.77018 18.463 4.70617 17.5813 3.90425 16.4817C3.10232 15.3821 2.58792 14.0995 2.40779 12.7505C2.22766 11.4015 2.38751 10.0289 2.87282 8.75742C3.35813 7.48593 4.1535 6.35589 5.18665 5.46999C6.2198 4.5841 7.45797 3.97045 8.78862 3.68482C10.1193 3.39919 11.5002 3.45063 12.8059 3.83447C14.1116 4.21831 15.3007 4.92238 16.2651 5.88268C17.2294 6.84298 17.9385 8.02907 18.3279 9.33314H20.4162C21.7596 9.3308 23.0528 9.84353 24.0296 10.7658C25.0064 11.6881 25.5925 12.9497 25.6673 14.291C25.742 15.6324 25.2997 16.9513 24.4314 17.9764C23.5631 19.0015 22.3349 19.6547 20.9996 19.8016"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"></path>
			<path
				d="M15.166 14L11.666 19.8333H16.3327L12.8327 25.6667"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"></path>
		</svg>
		<span class="brand__text">Storm Cloud</span>
		<span class="brand__badge">Блог</span>
	</a>

	<div class="topbar__quick">
		<a class="auth-btn" href={MAIN_SITE_URL} target="_blank" rel="noopener noreferrer">VPS</a>
		<button type="button" class="topbar-burger" id="topbar-burger" aria-expanded="false" aria-controls="topbar-mobile-menu" aria-label="Меню">
			<span class="topbar-burger__lines" aria-hidden="true">
				<span></span>
				<span></span>
				<span></span>
			</span>
		</button>
	</div>

	<div class="topbar-actions topbar-actions--desktop">
		<nav class="topbar-nav" aria-label="Навигация">
			<HeaderLink href="/" class="topbar-nav__btn">Главная</HeaderLink>
			<span class="topbar-nav__sep" aria-hidden="true"></span>
			<HeaderLink href="/blog" class="topbar-nav__btn">Блог</HeaderLink>
			<span class="topbar-nav__sep" aria-hidden="true"></span>
			<HeaderLink href="/about" class="topbar-nav__btn">О блоге</HeaderLink>
			<span class="topbar-nav__sep" aria-hidden="true"></span>
			<a
				href={INSTAGRAM_URL}
				class="topbar-nav__btn topbar-nav__btn--icon"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="Instagram StormNet Cloud"
			>
				<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
					<path
						fill="currentColor"
						d="M7.8 2h8.4A5.8 5.8 0 0 1 22 7.8v8.4A5.8 5.8 0 0 1 16.2 22H7.8A5.8 5.8 0 0 1 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2zm0 2A3.8 3.8 0 0 0 4 7.8v8.4A3.8 3.8 0 0 0 7.8 20h8.4a3.8 3.8 0 0 0 3.8-3.8V7.8A3.8 3.8 0 0 0 16.2 4H7.8zm9.65 1.5a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5zM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6z"
					></path>
				</svg>
			</a>
			<a
				href={TIKTOK_URL}
				class="topbar-nav__btn topbar-nav__btn--icon"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="TikTok StormNet Cloud"
			>
				<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
					<path
						fill="currentColor"
						d="M16.6 5.82s.51.5 0 0A4.28 4.28 0 0 1 15.54 3h-3.09v12.4a2.59 2.59 0 0 1-2.59 2.5c-1.42 0-2.6-1.16-2.6-2.6 0-1.72 1.66-3.01 3.37-2.48V9.66c-3.45-.46-6.47 2.22-6.47 5.64 0 3.33 2.76 5.7 5.69 5.7 3.14 0 5.69-2.55 5.69-5.7V9.01a7.35 7.35 0 0 0 4.3 1.38V7.3a4.1 4.1 0 0 1-1-.48z"
					></path>
				</svg>
			</a>
		</nav>
		<a class="auth-btn" href={MAIN_SITE_URL} target="_blank" rel="noopener noreferrer">Арендовать VPS</a>
	</div>
</header>

<div class="topbar-mobile" id="topbar-mobile-menu" aria-hidden="true">
	<button type="button" class="topbar-mobile__backdrop" id="topbar-mobile-backdrop" aria-label="Закрыть меню"></button>
	<div class="topbar-mobile__panel">
		<div class="topbar-mobile__head">
			<span class="brand__text">{SITE_TITLE}</span>
			<button type="button" class="topbar-burger topbar--menu-open" id="topbar-mobile-close" aria-label="Закрыть меню">
				<span class="topbar-burger__lines" aria-hidden="true">
					<span></span>
					<span></span>
					<span></span>
				</span>
			</button>
		</div>
		<nav class="topbar-mobile__nav" aria-label="Мобильная навигация">
			<HeaderLink href="/">Главная</HeaderLink>
			<HeaderLink href="/blog">Блог</HeaderLink>
			<HeaderLink href="/about">О блоге</HeaderLink>
			<a href={INSTAGRAM_URL} target="_blank" rel="noopener noreferrer">Instagram</a>
			<a href={TIKTOK_URL} target="_blank" rel="noopener noreferrer">TikTok</a>
		</nav>
		<div class="topbar-mobile__cta">
			<a class="auth-btn" href={MAIN_SITE_URL} target="_blank" rel="noopener noreferrer">Арендовать VPS</a>
		</div>
	</div>
</div>

<script>
	const topbar = document.getElementById('site-topbar');
	const menu = document.getElementById('topbar-mobile-menu');
	const openBtn = document.getElementById('topbar-burger');
	const closeBtn = document.getElementById('topbar-mobile-close');
	const backdrop = document.getElementById('topbar-mobile-backdrop');

	function setMenuOpen(open) {
		menu?.classList.toggle('is-open', open);
		topbar?.classList.toggle('topbar--menu-open', open);
		document.body.classList.toggle('topbar-menu-open', open);
		openBtn?.setAttribute('aria-expanded', String(open));
		menu?.setAttribute('aria-hidden', String(!open));
	}

	openBtn?.addEventListener('click', () => setMenuOpen(true));
	closeBtn?.addEventListener('click', () => setMenuOpen(false));
	backdrop?.addEventListener('click', () => setMenuOpen(false));

	document.addEventListener('keydown', (event) => {
		if (event.key === 'Escape') setMenuOpen(false);
	});
</script>
