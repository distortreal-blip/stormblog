---
import {
	GISCUS_CATEGORY,
	GISCUS_CATEGORY_ID,
	GISCUS_ENABLED,
	GISCUS_REPO,
	GISCUS_REPO_ID,
} from '../consts';

interface Props {
	term?: string;
}

const { term } = Astro.props;
const isConfigured = GISCUS_ENABLED && GISCUS_REPO_ID && GISCUS_CATEGORY_ID;
---

{
	isConfigured && (
		<section class="comments" data-nosnippet aria-label="Комментарии к статье">
			<div class="giscus" id="giscus-root"></div>
			<script
				is:inline
				define:vars={{
					repo: GISCUS_REPO,
					repoId: GISCUS_REPO_ID,
					category: GISCUS_CATEGORY,
					categoryId: GISCUS_CATEGORY_ID,
				}}
			>
				const container = document.getElementById('giscus-root');
				if (!container) {
					throw new Error('Giscus container not found');
				}

				const script = document.createElement('script');
				script.src = 'https://giscus.app/client.js';
				script.setAttribute('data-repo', repo);
				script.setAttribute('data-repo-id', repoId);
				script.setAttribute('data-category', category);
				script.setAttribute('data-category-id', categoryId);
				script.setAttribute('data-mapping', 'pathname');
				script.setAttribute('data-strict', '0');
				script.setAttribute('data-reactions-enabled', '1');
				script.setAttribute('data-emit-metadata', '0');
				script.setAttribute('data-input-position', 'bottom');
				script.setAttribute('data-theme', 'preferred_color_scheme');
				script.setAttribute('data-lang', 'ru');
				script.crossOrigin = 'anonymous';
				script.async = true;
				container.appendChild(script);
			</script>
		</section>
	)
}

{
	!isConfigured && (
		<section class="comments comments--placeholder" data-nosnippet aria-label="Обсуждение статьи">
			<p>
				Обсуждение скоро будет доступно. Пока пишите в
				<a href="https://t.me/stormnetofficial" target="_blank" rel="noopener noreferrer">Telegram</a>.
			</p>
		</section>
	)
}
