---
import BaseHead, { type ArticleMeta, type BreadcrumbItem } from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	description: string;
	type?: 'website' | 'article';
	article?: ArticleMeta;
	breadcrumbs?: BreadcrumbItem[];
	showReadingProgress?: boolean;
}

const { title, description, type = 'website', article, breadcrumbs, showReadingProgress = false } =
	Astro.props;
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead
			title={title}
			description={description}
			type={type}
			article={article}
			breadcrumbs={breadcrumbs}
		/>
		<slot name="head" />
	</head>
	<body>
		<div class="site-shell">
			<div class="page">
				<Header />
				<main class="main-content">
					<slot name="before" />
					<slot />
				</main>
				<Footer />
			</div>
		</div>
		{showReadingProgress && <slot name="progress" />}
	</body>
</html>
