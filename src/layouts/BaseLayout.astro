---
import BaseHead, { type ArticleMeta, type BreadcrumbItem } from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import YandexMetrika from '../components/YandexMetrika.astro';

import type { ItemListMeta } from '../data/seo';

interface Props {
	title: string;
	description: string;
	type?: 'website' | 'article';
	keywords?: string[];
	robots?: string;
	article?: ArticleMeta;
	breadcrumbs?: BreadcrumbItem[];
	itemList?: ItemListMeta;
	showReadingProgress?: boolean;
}

const {
	title,
	description,
	type = 'website',
	keywords,
	robots,
	article,
	breadcrumbs,
	itemList,
	showReadingProgress = false,
} = Astro.props;
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead
			title={title}
			description={description}
			type={type}
			keywords={keywords}
			robots={robots}
			article={article}
			breadcrumbs={breadcrumbs}
			itemList={itemList}
		/>
		<slot name="head" />
	</head>
	<body>
		<div class="site-shell">
			<div class="page">
				<Header />
				<main class="main-content">
					<slot name="before" />
					<slot />
				</main>
				<Footer />
			</div>
		</div>
		{showReadingProgress && <slot name="progress" />}
		<YandexMetrika />
	</body>
</html>
