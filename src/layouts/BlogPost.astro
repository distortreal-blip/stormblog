---
import { getImage } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import ArticleAuthor from '../components/ArticleAuthor.astro';
import ArticleFAQ from '../components/ArticleFAQ.astro';
import GiscusComments from '../components/GiscusComments.astro';
import RecommendedReading from '../components/RecommendedReading.astro';
import ArticleCover from '../components/ArticleCover.astro';
import ArticleNav from '../components/ArticleNav.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FormattedDate from '../components/FormattedDate.astro';
import ArticleViews from '../components/ArticleViews.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import TableOfContents from '../components/TableOfContents.astro';
import ItNewsSidebar from '../components/ItNewsSidebar.astro';
import BaseLayout from './BaseLayout.astro';
import { SITE_URL } from '../consts';
import type { BlogPost } from '../utils/blog';
import {
	extractHeadings,
	formatReadingTime,
	getAdjacentPosts,
	getCategoryPath,
	getCategorySlug,
	getPostPath,
	getReadingTimeMinutes,
	getRecommendedPosts,
	getRelatedPosts,
} from '../utils/blog';
import { ARTICLE_FAQ, RECOMMENDED_LINKS } from '../data/seo';

interface Props {
	post: CollectionEntry<'blog'>;
	allPosts: BlogPost[];
}

const { post, allPosts } = Astro.props;
const { title, description, pubDate, updatedDate, category, heroImage, keywords, imageAlt } = post.data;
const readingMinutes = getReadingTimeMinutes(post.body ?? '');
const readingTime = formatReadingTime(readingMinutes);
const wordCount = post.body?.trim().split(/\s+/).filter(Boolean).length ?? 0;
const headings = extractHeadings(post.body ?? '');
const { prev, next } = getAdjacentPosts(post, allPosts);
const related = getRelatedPosts(post, allPosts, 6);
const recommended = getRecommendedPosts(post, allPosts, RECOMMENDED_LINKS[post.id] ?? [], 6);
const faqItems = ARTICLE_FAQ[post.id] ?? [];
const articleUrl = new URL(getPostPath(post.id), Astro.site).href;
const coverAlt =
	imageAlt ?? `${title} — иллюстрация к статье Storm Cloud Blog, категория ${category}`;
const stableOgImage = heroImage ? `${SITE_URL}/og/${post.id}.webp` : `${SITE_URL}favicon.svg`;

const categorySlug = getCategorySlug(category);
const breadcrumbs = [
	{ label: 'Главная', href: '/' },
	{ label: 'Статьи', href: '/blog/' },
	...(categorySlug ? [{ label: category, href: getCategoryPath(categorySlug) }] : []),
	{ label: title },
];

const optimizedCover = heroImage
	? await getImage({ src: heroImage, width: 1200, height: 630 })
	: null;
---

<BaseLayout
	title={title}
	description={description}
	type="article"
	showReadingProgress={true}
	article={{
		title,
		description,
		pubDate,
		updatedDate,
		category,
		url: articleUrl,
		image: stableOgImage,
		imageAlt: coverAlt,
		keywords,
		faq: faqItems,
		wordCount,
		timeRequiredMinutes: readingMinutes,
	}}
	breadcrumbs={breadcrumbs}
>
	{optimizedCover && (
		<link
			slot="head"
			rel="preload"
			as="image"
			href={optimizedCover.src}
			imagesrcset={`${optimizedCover.src} 1200w`}
			imagesizes="(max-width: 768px) 100vw, 1200px"
		/>
	)}

	<ReadingProgress slot="progress" />

	<div class="article-shell">
		<Breadcrumbs items={breadcrumbs} />

		<ArticleCover
			id={post.id}
			category={category}
			title={title}
			heroImage={heroImage}
			variant="hero"
			imageAlt={coverAlt}
		/>

		<div class="article-layout article-layout--with-news">
			<aside class="article-sidebar article-sidebar--left">
				<TableOfContents headings={headings} />
			</aside>

			<article class="article-content">
				<header class="article-header">
					<div class="article-header__meta">
						<span class="article-header__category">{category}</span>
						<span>·</span>
						<span>{readingTime}</span>
						<span>·</span>
						<FormattedDate date={pubDate} />
						<span>·</span>
						<ArticleViews slug={post.id} />
						{
							updatedDate && (
								<>
									<span>·</span>
									<span>
										Обновлено <FormattedDate date={updatedDate} />
									</span>
								</>
							)
						}
					</div>
					<h1 class="article-header__title">{title}</h1>
					<p class="article-header__lead">{description}</p>
					<ArticleAuthor />
				</header>

				<div class="article-body">
					<slot />
				</div>

				<RecommendedReading posts={recommended} />
				<ArticleFAQ items={faqItems} />
				<ArticleNav prevPost={prev} nextPost={next} />
				<RelatedArticles posts={related} />
				<GiscusComments term={getPostPath(post.id)} />
			</article>

			<aside class="article-sidebar article-sidebar--right">
				<ItNewsSidebar />
			</aside>
		</div>
	</div>
</BaseLayout>
