---
import { getImage } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import ArticleAuthor from '../components/ArticleAuthor.astro';
import ArticleFAQ from '../components/ArticleFAQ.astro';
import GiscusComments from '../components/GiscusComments.astro';
import RecommendedReading from '../components/RecommendedReading.astro';
import ArticleCover from '../components/ArticleCover.astro';
import ArticleNav from '../components/ArticleNav.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FormattedDate from '../components/FormattedDate.astro';
import ArticleViews from '../components/ArticleViews.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import TableOfContents from '../components/TableOfContents.astro';
import BaseLayout from './BaseLayout.astro';
import type { BlogPost } from '../utils/blog';
import {
	extractHeadings,
	formatReadingTime,
	getAdjacentPosts,
	getPostPath,
	getReadingTimeMinutes,
	getRecommendedPosts,
	getRelatedPosts,
} from '../utils/blog';
import { ARTICLE_FAQ, RECOMMENDED_LINKS } from '../data/seo';

interface Props {
	post: CollectionEntry<'blog'>;
	allPosts: BlogPost[];
}

const { post, allPosts } = Astro.props;
const { title, description, pubDate, updatedDate, category, heroImage, keywords } = post.data;
const readingTime = formatReadingTime(getReadingTimeMinutes(post.body ?? ''));
const headings = extractHeadings(post.body ?? '');
const { prev, next } = getAdjacentPosts(post, allPosts);
const related = getRelatedPosts(post, allPosts, 6);
const recommended = getRecommendedPosts(post, allPosts, RECOMMENDED_LINKS[post.id] ?? [], 6);
const faqItems = ARTICLE_FAQ[post.id] ?? [];
const articleUrl = new URL(getPostPath(post.id), Astro.site).href;
const optimizedCover = heroImage
	? await getImage({ src: heroImage, width: 1200, height: 630 })
	: null;
const ogImage = optimizedCover
	? new URL(optimizedCover.src, Astro.site).href
	: `${Astro.site}favicon.svg`;

const breadcrumbs = [
	{ label: 'Главная', href: '/' },
	{ label: 'Статьи', href: '/blog/' },
	{ label: title },
];
---

<BaseLayout
	title={title}
	description={description}
	type="article"
	showReadingProgress={true}
	article={{
		title,
		description,
		pubDate,
		updatedDate,
		category,
		url: articleUrl,
		image: ogImage,
		keywords,
		faq: faqItems,
	}}
	breadcrumbs={breadcrumbs}
>
	<ReadingProgress slot="progress" />

	<div class="article-shell">
		<Breadcrumbs items={breadcrumbs} />

		<ArticleCover
			id={post.id}
			category={category}
			title={title}
			heroImage={heroImage}
			variant="hero"
			imageAlt={title}
		/>

		<div class="article-layout">
			<TableOfContents headings={headings} />

			<article class="article-content">
				<header class="article-header">
					<div class="article-header__meta">
						<span class="article-header__category">{category}</span>
						<span>·</span>
						<span>{readingTime}</span>
						<span>·</span>
						<FormattedDate date={pubDate} />
						<span>·</span>
						<ArticleViews slug={post.id} />
						{
							updatedDate && (
								<>
									<span>·</span>
									<span>
										Обновлено <FormattedDate date={updatedDate} />
									</span>
								</>
							)
						}
					</div>
					<h1 class="article-header__title">{title}</h1>
					<p class="article-header__lead">{description}</p>
					<ArticleAuthor />
				</header>

				<div class="article-body">
					<slot />
				</div>

				<RecommendedReading posts={recommended} />
				<ArticleFAQ items={faqItems} />
				<ArticleNav prevPost={prev} nextPost={next} />
				<RelatedArticles posts={related} />
				<GiscusComments term={getPostPath(post.id)} />
			</article>
		</div>
	</div>
</BaseLayout>
