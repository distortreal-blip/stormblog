---
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="hero-panel fade-in">
		<span class="section-kicker">Storm Cloud Blog</span>
		<h1 class="hero-title">Практика про VPS, серверы и облака</h1>
		<p class="hero-subtitle">{SITE_DESCRIPTION}</p>
		<div class="hero-actions">
			<a class="auth-btn" href="/blog">Читать статьи</a>
			<a class="choose-btn" href="https://stormnetcloud.com/" target="_blank" rel="noopener noreferrer">
				Арендовать VPS
			</a>
		</div>
		<div class="hero-tags">
			<span class="hero-tag">VPS</span>
			<span class="hero-tag">DevOps</span>
			<span class="hero-tag">Безопасность</span>
			<span class="hero-tag">Облака</span>
			<span class="hero-tag">Инфраструктура</span>
			<span class="hero-tag">Почасовая аренда</span>
		</div>
	</section>

	<section class="content-section">
		<h2 class="section-heading">Последние статьи</h2>
		<p class="section-lead">Инструкции и разборы без лишней теории</p>
		<ul class="blog-grid">
			{
				posts.map((post) => (
					<li class="blog-card">
						<a href={`/blog/${post.id}/`}>
							<h3 class="blog-card__title">{post.data.title}</h3>
							<p class="blog-card__excerpt">{post.data.description}</p>
							<p class="blog-card__date">
								<FormattedDate date={post.data.pubDate} />
							</p>
						</a>
					</li>
				))
			}
		</ul>
	</section>
</BaseLayout>
