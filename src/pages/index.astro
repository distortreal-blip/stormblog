---
import { getCollection } from 'astro:content';
import ArticleCard from '../components/ArticleCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { sortPostsByDate } from '../utils/blog';

const posts = sortPostsByDate(await getCollection('blog'));
const [featured, ...rest] = posts;
const latest = rest.slice(0, 3);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="hero">
		<h1 class="hero__title">Статьи о VPS, серверах и облачной инфраструктуре</h1>
		<p class="hero__subtitle">
			Практические руководства, обзоры и инструкции для разработчиков, системных администраторов и
			всех, кто работает с облачной инфраструктурой.
		</p>
		<div class="hero__actions">
			<a class="btn btn-primary" href="/blog">Все статьи</a>
			<a class="btn btn-ghost" href="https://stormnetcloud.com/" target="_blank" rel="noopener noreferrer">
				Арендовать VPS
			</a>
		</div>
		<div class="hero__topics">
			<a href="/blog">VPS</a>
			<span>·</span>
			<a href="/blog">DevOps</a>
			<span>·</span>
			<a href="/blog">Linux</a>
			<span>·</span>
			<a href="/blog">Docker</a>
			<span>·</span>
			<a href="/blog">Безопасность</a>
			<span>·</span>
			<a href="/blog">Облака</a>
		</div>
	</section>

	{
		featured && (
			<section class="section">
				<div class="section__header">
					<h2 class="section__title">Новые статьи</h2>
				</div>
				<ul class="article-grid">
					<ArticleCard post={featured} featured />
				</ul>
			</section>
		)
	}

	{
		latest.length > 0 && (
			<section class="section">
				<div class="section__header">
					<h2 class="section__title">Последние статьи</h2>
					<a class="section__link" href="/blog">Смотреть все →</a>
				</div>
				<ul class="article-grid article-grid--compact">
					{latest.map((post) => (
						<ArticleCard post={post} />
					))}
				</ul>
			</section>
		)
	}
</BaseLayout>
