---
import { getCollection } from 'astro:content';
import ArticleCard from '../components/ArticleCard.astro';
import CategoryTags from '../components/CategoryTags.astro';
import GuideCard from '../components/GuideCard.astro';
import TopicOfMonth from '../components/TopicOfMonth.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { GUIDES } from '../data/seo';
import { SITE_DESCRIPTION, SITE_TITLE, TOPIC_OF_MONTH } from '../consts';
import { sortPostsByDate } from '../utils/blog';

const allPosts = sortPostsByDate(await getCollection('blog'));
const topicPost = allPosts.find((post) => post.id === TOPIC_OF_MONTH.slug);
const listPosts = topicPost
	? allPosts.filter((post) => post.id !== TOPIC_OF_MONTH.slug)
	: allPosts;
const [featured, ...rest] = listPosts;
const latest = rest.slice(0, 3);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<div class="hero-shell">
		<div class="hero-shell__main">
			<section class="hero">
				<h1 class="hero__title">Статьи о VPS, серверах и облачной инфраструктуре</h1>
				<p class="hero__subtitle">
					Практические руководства, обзоры и инструкции для разработчиков, системных администраторов и
					всех, кто работает с облачной инфраструктурой.
				</p>
				<div class="hero__actions">
					<a class="btn btn-primary" href="/blog">Все статьи</a>
					<a class="btn btn-ghost" href="https://stormnetcloud.com/" target="_blank" rel="noopener noreferrer">
						Арендовать VPS
					</a>
				</div>
				<CategoryTags showAll={false} />
			</section>
		</div>
		{topicPost && <TopicOfMonth post={topicPost} />}
	</div>

	{
		featured && (
			<section class="section">
				<div class="section__header">
					<h2 class="section__title">Новые статьи</h2>
				</div>
				<ul class="article-grid">
					<ArticleCard post={featured} featured />
				</ul>
			</section>
		)
	}

	{
		latest.length > 0 && (
			<section class="section">
				<div class="section__header">
					<h2 class="section__title">Последние статьи</h2>
					<a class="section__link" href="/blog">Смотреть все →</a>
				</div>
				<ul class="article-grid article-grid--compact">
					{latest.map((post) => (
						<ArticleCard post={post} />
					))}
				</ul>
			</section>
		)
	}

	<section class="section">
		<div class="section__header">
			<h2 class="section__title">Подборки и гиды</h2>
			<a class="section__link" href="/blog">Все статьи →</a>
		</div>
		<ul class="guides-grid">
			{GUIDES.map((guide) => (
				<GuideCard guide={guide} />
			))}
		</ul>
	</section>
</BaseLayout>
