---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { MAIN_SITE_URL } from '../../consts';
---

<BaseLayout title="Password Generator" description="Генератор надёжных паролей онлайн.">
	<section class="tool-page">
		<h1>Password Generator</h1>
		<p class="tool-page__lead">Сгенерируйте надёжный пароль для сервера, базы или сервиса.</p>
		<div class="tool-panel">
			<label for="password-length">Длина: <span id="password-length-value">16</span></label>
			<input id="password-length" type="range" min="8" max="64" value="16" />
			<div class="tool-row">
				<input id="password-output" class="tool-input" readonly />
				<button type="button" class="btn btn-primary" id="password-generate">Сгенерировать</button>
				<button type="button" class="btn btn-ghost" id="password-copy">Копировать</button>
			</div>
		</div>
		<p class="tool-cta">Храните секреты на VPS — <a href={MAIN_SITE_URL}>аренда от StormNet Cloud</a>.</p>
	</section>
	<script>
		const lengthInput = document.getElementById('password-length');
		const lengthValue = document.getElementById('password-length-value');
		const output = document.getElementById('password-output');
		const alphabet = 'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*-_';

		function generatePassword() {
			if (!lengthInput || !output) return;
			const length = Number(lengthInput.value);
			const bytes = crypto.getRandomValues(new Uint8Array(length));
			output.value = Array.from(bytes, (byte) => alphabet[byte % alphabet.length]).join('');
		}

		lengthInput?.addEventListener('input', () => {
			if (lengthValue && lengthInput) lengthValue.textContent = lengthInput.value;
		});

		document.getElementById('password-generate')?.addEventListener('click', generatePassword);
		document.getElementById('password-copy')?.addEventListener('click', async () => {
			if (!output?.value) return;
			await navigator.clipboard.writeText(output.value);
		});

		generatePassword();
	</script>
</BaseLayout>
