---
import { getCollection } from 'astro:content';
import ArticleCard from '../../components/ArticleCard.astro';
import CategoryTags from '../../components/CategoryTags.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION } from '../../consts';
import { GUIDES } from '../../data/seo';
import { sortPostsByDate } from '../../utils/blog';

const posts = sortPostsByDate(await getCollection('blog'));
---

<BaseLayout title="Статьи" description={SITE_DESCRIPTION}>
	<section class="hero">
		<h1 class="hero__title">Все статьи</h1>
		<p class="hero__subtitle">
			Практические материалы о VPS, серверах, DevOps, разработке и облачной инфраструктуре.
		</p>
		<CategoryTags />
	</section>

	<section class="section">
		<div class="section__header">
			<h2 class="section__title">Подборки и гиды</h2>
		</div>
		<ul class="guides-grid">
			{GUIDES.map((guide) => (
				<li class="guide-card">
					<a href={`/blog/guide/${guide.slug}/`}>
						<h3>{guide.title}</h3>
						<p>{guide.description}</p>
					</a>
				</li>
			))}
		</ul>
	</section>

	<section class="section">
		<ul class="article-grid article-grid--compact">
			{posts.map((post, index) => (
				<ArticleCard post={post} featured={index === 0} />
			))}
		</ul>
	</section>
</BaseLayout>
