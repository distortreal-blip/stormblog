---
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Блог" description={SITE_DESCRIPTION}>
	<section class="hero-panel fade-in">
		<span class="section-kicker">Статьи</span>
		<h1 class="hero-title">Блог</h1>
		<p class="hero-subtitle">Статьи о VPS, серверах, облаках и инфраструктуре</p>
	</section>

	<section class="content-section">
		<ul class="blog-grid">
			{
				posts.map((post) => (
					<li class="blog-card">
						<a href={`/blog/${post.id}/`}>
							<h2 class="blog-card__title">{post.data.title}</h2>
							<p class="blog-card__excerpt">{post.data.description}</p>
							<p class="blog-card__date">
								<FormattedDate date={post.data.pubDate} />
							</p>
						</a>
					</li>
				))
			}
		</ul>
	</section>
</BaseLayout>
